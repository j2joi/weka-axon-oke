# Generated: Thu Apr 16 22:40:16 EDT 2026
# WEKA_OPERATOR_VERSION : v1.11.0
# DEPLOY_DIR            : /Users/julian.ortiz/Documents/Weka/Cloud/OCI/demo-oke/oracle-oke-axon/deploy
# QUAY_USERNAME         : <QUAY_USERNAME>

════════════════════════════════════════════
  Phase 4: Install WEKA operator CRDs (v1.11.0)
════════════════════════════════════════════

helm show crds \
  oci://quay.io/weka.io/helm/weka-operator \
  --version "v1.11.0" \
| kubectl apply --server-side -f -

kubectl get crds | grep -i weka


════════════════════════════════════════════
  Phase 5: Create namespaces + Quay.io image pull secrets
════════════════════════════════════════════

kubectl create namespace weka-operator-system \
  --dry-run=client -o yaml \
| kubectl apply -f -

kubectl create secret docker-registry quay-io-robot-secret \
  --docker-server=quay.io \
  --docker-username="<QUAY_USERNAME>" \
  --docker-password="<QUAY_PASSWORD>" \
  --docker-email="<QUAY_USERNAME>" \
  --namespace=weka-operator-system \
  --dry-run=client -o yaml \
| kubectl apply -f -

kubectl create secret docker-registry quay-io-robot-secret \
  --docker-server=quay.io \
  --docker-username="<QUAY_USERNAME>" \
  --docker-password="<QUAY_PASSWORD>" \
  --docker-email="<QUAY_USERNAME>" \
  --namespace=default \
  --dry-run=client -o yaml \
| kubectl apply -f -


════════════════════════════════════════════
  Phase 6: Helm install WEKA operator (v1.11.0)
════════════════════════════════════════════

helm upgrade --install weka-operator \
  oci://quay.io/weka.io/helm/weka-operator \
  --namespace weka-operator-system \
  --version "v1.11.0" \
  --set imagePullSecret=quay-io-robot-secret \
  --set csi.installationEnabled=true \
  --wait \
  --timeout 5m0s

kubectl rollout status deployment/weka-operator-controller-manager \
  -n weka-operator-system \
  --timeout=300s

kubectl get pods -n weka-operator-system


════════════════════════════════════════════
  Phase 7: Sign Drives — apply WekaPolicy
════════════════════════════════════════════

kubectl apply -f "/Users/julian.ortiz/Documents/Weka/Cloud/OCI/demo-oke/oracle-oke-axon/deploy/sign-drives.yaml"

kubectl get wekapolicy sign-all-drives-policy -n default


════════════════════════════════════════════
  Phase 8: Deploy WekaCluster CR
════════════════════════════════════════════

kubectl apply -f "/Users/julian.ortiz/Documents/Weka/Cloud/OCI/demo-oke/oracle-oke-axon/deploy/weka-cluster.yaml"

# Polling loop — runs every 15s until Ready (timeout: 1200s)
kubectl get wekacluster cluster-dev \
  -n default \
  -o jsonpath='{.status.status}'

# On Ready:
kubectl get wekacluster cluster-dev -n default

# On Error/Failed:
kubectl get wekacluster cluster-dev \
  -n default \
  -o jsonpath='{.status.conditions}' | python3 -m json.tool


════════════════════════════════════════════
  Phase 9: Deploy WekaClient CR
════════════════════════════════════════════

kubectl apply -f "/Users/julian.ortiz/Documents/Weka/Cloud/OCI/demo-oke/oracle-oke-axon/deploy/weka-client.yaml"

kubectl get wekaclient cluster-clients -n default

kubectl get pods -n default

