# weka-deploy.env.example
# Copy this file to weka-deploy.env and fill in values.
# weka-deploy.env is gitignored — never commit credentials.
#
# Environment variables set in your shell before running deploy-weka.sh
# take precedence over values in this file.

# ── OCI authentication (choose one approach) ──────────────────────────────────
#
# Option A — OCI config file (recommended)
#   Set OCI_CONFIG_FILE and the script reads tenancy, user, fingerprint,
#   key_file, and region automatically.  Use OCI_CONFIG_PROFILE to select a
#   non-DEFAULT profile.
#
# OCI_CONFIG_FILE="$HOME/.oci/config"
# OCI_CONFIG_PROFILE="DEFAULT"
#
# Option B — explicit variables
#   Required only when OCI_CONFIG_FILE is NOT set.
#
# TENANCY_OCID="ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# USER_OCID="ocid1.user.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
# FINGERPRINT="xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx:xx"
# PRIVATE_KEY_PATH="$HOME/.oci/oci_api_key.pem"
# REGION="us-phoenix-1"

# ── Always required ───────────────────────────────────────────────────────────

COMPARTMENT_OCID="ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

SSH_PUBLIC_KEY_PATH="$HOME/.ssh/id_rsa.pub"
SSH_PRIVATE_KEY_PATH="$HOME/.ssh/id_rsa"

# OCID of the Ubuntu OKE image for the worker nodes.
# Find available images with:
#   oci compute image list --compartment-id <compartment-ocid> \
#     --operating-system "Canonical Ubuntu" --query 'data[].id'
IMAGE_ID="ocid1.image.oc1.phx.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# ── WEKA deployment variables ─────────────────────────────────────────────────

# Quay.io robot account credentials (provided by WEKA support)
QUAY_USERNAME="weka-robot+your_account_name"
QUAY_PASSWORD="your_quay_robot_password"

# WEKA cluster join address(es).
# Comma-separated list of ip:port (use the cluster management IP or load balancer).
# Port 14000 is the default WEKA cluster port.

# ── Optional overrides (defaults shown) ───────────────────────────────────────

# WEKA container image version
# WEKA_IMAGE="quay.io/weka.io/weka-in-container:5.1.0.605"

# WEKA operator Helm chart version
# WEKA_OPERATOR_VERSION="v1.11.0"

# Number of additional data NICs per node for DPDK mode
# DATA_NICS_NUMBER=2

# Number of WEKA cores per client node
# CORES_NUM=4

# Base UDP port for WEKA inter-process communication
# BASE_PORT=46000

# Path where the extracted kubeconfig will be saved
# KUBECONFIG_FILE="./deploy/kubeconfig"

# Kubernetes namespace for the WEKA CSI plugin (phase 8)
# CSI_WEKAFS_NAMESPACE="csi-wekafs"
